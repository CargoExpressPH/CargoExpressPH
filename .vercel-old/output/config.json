{
  "version": 3,
  "routes": [
    {
      "src": "^/sw\\.js$",
      "headers": {
        "Cache-Control": "no-cache, no-store, must-revalidate",
        "Service-Worker-Allowed": "/"
      },
      "continue": true
    },
    {
      "src": "^/manifest\\.json$",
      "headers": {
        "Cache-Control": "no-cache"
      },
      "continue": true
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "^(?:/(.*))$",
      "dest": "/index.html",
      "check": true
    },
    {
      "handle": "error"
    },
    {
      "status": 404,
      "src": "^(?!/api).*$",
      "dest": "/404.html"
    }
  ],
  "framework": {
    "slug": "vite",
    "version": "6.4.2"
  },
  "crons": []
}
